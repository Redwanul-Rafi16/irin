<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>For Irin Jahan Bristy</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #FFF0F3;
    --rose: #D6336C;
    --rose-dark: #B0224F;
    --pink-soft: #FFC2D1;
    --plum: #4A1942;
    --gold: #F4A261;
    --white: #FFFFFF;
  }

  *{ box-sizing: border-box; }

  html, body{
    margin:0;
    padding:0;
    width:100%;
    height:100%;
    overflow:hidden;
  }

  body{
    background: radial-gradient(circle at 50% 20%, #FFE3EA 0%, var(--bg) 60%);
    font-family: 'Poppins', sans-serif;
    color: var(--plum);
    display:flex;
    align-items:center;
    justify-content:center;
    position:relative;
  }

  /* floating hearts background */
  .heart{
    position:absolute;
    bottom:-10%;
    font-size: 22px;
    color: var(--pink-soft);
    opacity:0.55;
    animation: float-up linear infinite;
    pointer-events:none;
    user-select:none;
  }

  @keyframes float-up{
    0%{ transform: translateY(0) translateX(0) rotate(0deg); opacity:0; }
    10%{ opacity:0.55; }
    90%{ opacity:0.45; }
    100%{ transform: translateY(-115vh) translateX(var(--drift, 20px)) rotate(360deg); opacity:0; }
  }

  .card{
    position:relative;
    z-index:2;
    background: var(--white);
    border-radius: 28px;
    padding: 48px 40px 56px;
    width: min(92vw, 460px);
    box-shadow: 0 20px 60px rgba(214, 51, 108, 0.18);
    text-align:center;
    transition: transform 0.25s ease;
  }

  .eyebrow{
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--rose);
    font-weight:600;
    margin-bottom: 6px;
  }

  .name{
    font-family:'Dancing Script', cursive;
    font-size: 30px;
    color: var(--rose-dark);
    margin: 0 0 18px;
  }

  .question{
    font-family: 'Dancing Script', cursive;
    font-weight: 700;
    font-size: clamp(26px, 6vw, 34px);
    line-height: 1.25;
    color: var(--plum);
    margin: 0 0 36px;
    min-height: 110px;
    display:flex;
    align-items:center;
    justify-content:center;
    transition: opacity 0.2s ease;
  }

  .buttons{
    display:flex;
    align-items:center;
    justify-content:center;
    gap: 18px;
    flex-wrap: nowrap;
    position: relative;
    min-height: 90px;
  }

  button{
    border:none;
    border-radius: 999px;
    font-family:'Poppins', sans-serif;
    font-weight:600;
    cursor:pointer;
    transition: all 0.28s cubic-bezier(.34,1.56,.64,1), transform 0.15s ease;
    white-space: nowrap;
  }

  #yesBtn{
    background: var(--rose);
    color: var(--white);
    font-size: 17px;
    padding: 14px 30px;
    box-shadow: 0 8px 20px rgba(214,51,108,0.35);
  }

  #yesBtn:hover{
    background: var(--rose-dark);
    transform: scale(1.04);
  }

  #noBtn{
    background: var(--pink-soft);
    color: var(--rose-dark);
    font-size: 17px;
    padding: 14px 30px;
    position: relative;
  }

  #noBtn:hover{
    background: #ffd3dd;
  }

  .hint{
    margin-top: 22px;
    font-size: 12.5px;
    color: #B98AA0;
    font-style: italic;
    min-height: 16px;
  }

  /* celebration overlay */
  .overlay{
    position: fixed;
    inset: 0;
    background: radial-gradient(circle at 50% 30%, #FFE3EA 0%, var(--bg) 70%);
    display:flex;
    align-items:center;
    justify-content:center;
    flex-direction:column;
    text-align:center;
    opacity:0;
    pointer-events:none;
    transition: opacity 0.5s ease;
    z-index: 10;
    padding: 24px;
  }

  .overlay.show{
    opacity:1;
    pointer-events:all;
  }

  .overlay .big-heart{
    font-size: 64px;
    animation: pulse 1.1s ease-in-out infinite;
  }

  @keyframes pulse{
    0%, 100%{ transform: scale(1); }
    50%{ transform: scale(1.15); }
  }

  .overlay h1{
    font-family:'Dancing Script', cursive;
    font-size: clamp(32px, 7vw, 46px);
    color: var(--rose-dark);
    margin: 14px 0 8px;
  }

  .overlay p{
    font-size: 15px;
    color: var(--plum);
    max-width: 360px;
  }

  .confetti{
    position:absolute;
    top:-5%;
    font-size: 20px;
    animation: confetti-fall linear forwards;
    pointer-events:none;
  }

  @keyframes confetti-fall{
    to{ transform: translateY(110vh) rotate(720deg); opacity: 0; }
  }
</style>
</head>
<body>

<div class="card" id="card">
  <div class="eyebrow">A small question for</div>
  <div class="name">Irin Jahan Bristy</div>
  <div class="question" id="question">Do you love me? 💗</div>
  <div class="buttons" id="buttons">
    <button id="yesBtn">Yes</button>
    <button id="noBtn">No</button>
  </div>
  <div class="hint" id="hint">&nbsp;</div>
</div>

<div class="overlay" id="overlay">
  <div class="big-heart">💖</div>
  <h1>Thank you, Bristy</h1>
  <p id="finalMessage">You just made me the happiest person alive. Forever grateful you said yes.</p>
</div>

<script>
  const questions = [
    "Do you love me? 💗",
    "Are you sure? Please accept my love 🥺",
    "Just think about it once more... please? 💌",
    "I promise I'll make you smile every day 🌸",
    "Pretty please, accept my love? 🙏",
    "One more chance? My heart is waiting 💓",
    "I'm not giving up on us 🌷",
    "Last try... say yes, please? 🥹"
  ];

  const noMessages = [
    "Hmm, the No button is getting shy...",
    "It's shrinking, just like my patience for sadness 😅",
    "Almost there, hang in there No button...",
    "It's barely holding on now...",
    "It's about to disappear forever..."
  ];

  let clickCount = 0;
  const maxClicks = 7;

  const yesBtn = document.getElementById('yesBtn');
  const noBtn = document.getElementById('noBtn');
  const question = document.getElementById('question');
  const hint = document.getElementById('hint');
  const card = document.getElementById('card');
  const buttonsWrap = document.getElementById('buttons');

  function updateSizes(){
    const yesScale = 1 + clickCount * 0.16;
    const noScale = Math.max(1 - clickCount * 0.15, 0);

    yesBtn.style.transform = `scale(${yesScale})`;
    yesBtn.style.fontWeight = 700;

    if(noScale <= 0.05){
      noBtn.style.opacity = '0';
      noBtn.style.pointerEvents = 'none';
      noBtn.style.transform = 'scale(0)';
    } else {
      noBtn.style.transform = `scale(${noScale})`;
      noBtn.style.opacity = String(Math.max(noScale, 0.2));
    }
  }

  noBtn.addEventListener('click', () => {
    clickCount++;

    // update question text
    const qIndex = Math.min(clickCount - 1, questions.length - 1);
    question.style.opacity = '0';
    setTimeout(() => {
      question.textContent = questions[qIndex];
      question.style.opacity = '1';
    }, 150);

    // update hint
    const hIndex = Math.min(clickCount - 1, noMessages.length - 1);
    hint.textContent = noMessages[hIndex];

    updateSizes();

    // make the No button dodge a little, for fun, while it still exists
    if(clickCount < maxClicks){
      const dodgeX = (Math.random() - 0.5) * 40;
      const dodgeY = (Math.random() - 0.5) * 14;
      noBtn.style.marginLeft = dodgeX + 'px';
      noBtn.style.marginTop = dodgeY + 'px';
    }

    if(clickCount >= maxClicks){
      noBtn.style.display = 'none';
      hint.textContent = "Looks like only Yes is left now 💗";
    }

    // tiny card pulse for feedback
    card.style.transform = 'scale(1.01)';
    setTimeout(() => { card.style.transform = 'scale(1)'; }, 150);
  });

  yesBtn.addEventListener('click', () => {
    document.getElementById('overlay').classList.add('show');
    launchConfetti();
  });

  function launchConfetti(){
    const emojis = ['💖','💗','💕','✨','🌸','💌'];
    for(let i=0;i<40;i++){
      const piece = document.createElement('div');
      piece.className = 'confetti';
      piece.textContent = emojis[Math.floor(Math.random()*emojis.length)];
      piece.style.left = Math.random() * 100 + 'vw';
      piece.style.animationDuration = (2.5 + Math.random()*2) + 's';
      piece.style.fontSize = (14 + Math.random()*14) + 'px';
      document.body.appendChild(piece);
      setTimeout(() => piece.remove(), 5000);
    }
  }

  // ambient floating hearts in background
  function spawnHeart(){
    const heart = document.createElement('div');
    heart.className = 'heart';
    heart.textContent = ['💗','💕','🌸','💖'][Math.floor(Math.random()*4)];
    heart.style.left = Math.random() * 100 + 'vw';
    heart.style.setProperty('--drift', (Math.random()*60 - 30) + 'px');
    heart.style.animationDuration = (8 + Math.random()*8) + 's';
    heart.style.fontSize = (16 + Math.random()*14) + 'px';
    document.body.appendChild(heart);
    setTimeout(() => heart.remove(), 17000);
  }
  setInterval(spawnHeart, 700);
  for(let i=0;i<6;i++) setTimeout(spawnHeart, i*300);
</script>

</body>
</html>
